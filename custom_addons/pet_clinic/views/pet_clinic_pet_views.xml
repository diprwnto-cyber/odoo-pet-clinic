<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Pet List View -->
    <record id="view_pet_clinic_pet_list" model="ir.ui.view">
        <field name="name">pet_clinic.pet.list</field>
        <field name="model">pet_clinic.pet</field>
        <field name="arch" type="xml">
            <list>
                <field name="id_pet" string="ID"/>
                <field name="name"/>
                <field name="owner_id"/>
                <field name="type_id"/>
                <field name="breed_id"/>
                <field name="gender"/>
                <field name="age"/>
                <field name="tgl_pendaftaran"/>
            </list>
        </field>
    </record>

    <!-- Pet Form View -->
    <record id="view_pet_clinic_pet_form" model="ir.ui.view">
        <field name="name">pet_clinic.pet.form</field>
        <field name="model">pet_clinic.pet</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_button_box" name="button_box">
                        <button name="action_view_visitations"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-stethoscope">
                            <field name="visitation_count" widget="statinfo" string="Visitations"/>
                        </button>
                        <button name="action_view_appointments"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-calendar">
                            <field name="appointment_count" widget="statinfo" string="Appointments"/>
                        </button>
                        <button name="action_view_services"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-cogs">
                            <field name="service_count" widget="statinfo" string="Services"/>
                        </button>
                    </div>
                    <field name="image" widget="image" class="oe_avatar" options="{'preview_image': 'image'}"/>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Pet Name"/>
                        </h1>
                        <field name="id_pet" readonly="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="owner_id"/>
                            <field name="type_id"/>
                            <field name="breed_id" domain="[('type_id', '=', type_id)]"/>
                            <field name="gender"/>
                        </group>
                        <group>
                            <field name="date_of_birth"/>
                            <field name="age"/>
                            <field name="sinyal_amon"/>
                            <field name="tgl_pendaftaran"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Medical History" name="medical_history">
                            <field name="medical_history_ids">
                                <list editable="bottom">
                                    <field name="date_start"/>
                                    <field name="doctor_id"/>
                                    <field name="anamnesa"/>
                                    <field name="diagnosis"/>
                                    <field name="therapy"/>
                                    <field name="temperature" string="Temperature (°C)"/>
                                    <field name="weight" string="Weight (Kg)"/>
                                    <field name="bcs" string="BCS (1-9)"/>
                                    <field name="action"/>
                                </list>
                            </field>
                        </page>
                        <page string="Visitations" name="visitations">
                            <field name="visitation_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="date_start"/>
                                    <field name="doctor_id"/>
                                    <field name="penanganan"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Appointments" name="appointments">
                            <field name="appointment_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="date"/>
                                    <field name="doctor_id"/>
                                    <field name="state"/>
                                </list>
                            </field>
                        </page>
                        <page string="Services" name="services">
                            <field name="service_ids">
                                <list>
                                    <field name="name"/>
                                    <field name="service_type"/>
                                    <field name="date_handling"/>
                                    <field name="total_price"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Pet Search View -->
    <record id="view_pet_clinic_pet_search" model="ir.ui.view">
        <field name="name">pet_clinic.pet.search</field>
        <field name="model">pet_clinic.pet</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="id_pet"/>
                <field name="owner_id"/>
                <field name="type_id"/>
                <field name="breed_id"/>
                <filter name="male" string="Male" domain="[('gender','=','male')]"/>
                <filter name="female" string="Female" domain="[('gender','=','female')]"/>
                <group expand="0" string="Group By">
                    <filter name="group_type" string="Type" context="{'group_by':'type_id'}"/>
                    <filter name="group_owner" string="Owner" context="{'group_by':'owner_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Pet Action -->
    <record id="action_pet_clinic_pet" model="ir.actions.act_window">
        <field name="name">Patients</field>
        <field name="res_model">pet_clinic.pet</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Register your first patient!
            </p>
        </field>
    </record>

</odoo>
