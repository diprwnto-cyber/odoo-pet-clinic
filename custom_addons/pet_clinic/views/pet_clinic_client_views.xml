<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Client List View -->
    <record id="view_pet_clinic_client_list" model="ir.ui.view">
        <field name="name">pet_clinic.client.list</field>
        <field name="model">pet_clinic.client</field>
        <field name="arch" type="xml">
            <list>
                <field name="id_client" string="ID"/>
                <field name="name"/>
                <field name="phone"/>
                <field name="email"/>
                <field name="address"/>
            </list>
        </field>
    </record>

    <!-- Client Form View -->
    <record id="view_pet_clinic_client_form" model="ir.ui.view">
        <field name="name">pet_clinic.client.form</field>
        <field name="model">pet_clinic.client</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <div class="oe_title">
                        <label for="name"/>
                        <h1>
                            <field name="name" placeholder="Client Name"/>
                        </h1>
                        <field name="id_client" readonly="1"/>
                    </div>
                    <group>
                        <group>
                            <field name="phone"/>
                            <field name="email"/>
                        </group>
                        <group>
                            <field name="address"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="Pets" name="pets">
                            <field name="pet_ids">
                                <list>
                                    <field name="id_pet" string="ID"/>
                                    <field name="name"/>
                                    <field name="type_id"/>
                                    <field name="breed_id"/>
                                    <field name="gender"/>
                                    <field name="age"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Client Search View -->
    <record id="view_pet_clinic_client_search" model="ir.ui.view">
        <field name="name">pet_clinic.client.search</field>
        <field name="model">pet_clinic.client</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="id_client"/>
                <field name="phone"/>
                <field name="email"/>
            </search>
        </field>
    </record>

    <!-- Client Action -->
    <record id="action_pet_clinic_client" model="ir.actions.act_window">
        <field name="name">Clients</field>
        <field name="res_model">pet_clinic.client</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create your first client!
            </p>
        </field>
    </record>

</odoo>
