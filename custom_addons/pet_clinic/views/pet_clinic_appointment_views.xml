<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Appointment List View -->
    <record id="view_pet_clinic_appointment_list" model="ir.ui.view">
        <field name="name">pet_clinic.appointment.list</field>
        <field name="model">pet_clinic.appointment</field>
        <field name="arch" type="xml">
            <list decoration-info="state=='draft'" decoration-warning="state=='confirmed'" decoration-success="state=='done'" decoration-muted="state=='cancel'">
                <field name="name"/>
                <field name="owner_id"/>
                <field name="pet_id"/>
                <field name="doctor_id"/>
                <field name="location_id"/>
                <field name="date"/>
                <field name="state" widget="badge" decoration-info="state=='draft'" decoration-warning="state=='confirmed'" decoration-success="state=='done'"/>
            </list>
        </field>
    </record>

    <!-- Appointment Form View -->
    <record id="view_pet_clinic_appointment_form" model="ir.ui.view">
        <field name="name">pet_clinic.appointment.form</field>
        <field name="model">pet_clinic.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm" string="Confirm"
                            type="object" class="btn-primary"
                            invisible="state != 'draft'"/>
                    <button name="action_create_visitation" string="Create Visitation"
                            type="object" class="btn-secondary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_done" string="Done"
                            type="object" class="btn-primary"
                            invisible="state != 'confirmed'"/>
                    <button name="action_cancel" string="Cancel"
                            type="object"
                            invisible="state in ('done', 'cancel')"/>
                    <button name="action_draft" string="Set to Draft"
                            type="object"
                            invisible="state != 'cancel'"/>
                    <field name="state" widget="statusbar"
                           statusbar_visible="draft,confirmed,done"/>
                </header>
                <sheet>
                    <div class="oe_title">
                        <h1>
                            <field name="name" readonly="1"/>
                        </h1>
                    </div>
                    <group>
                        <group>
                            <field name="owner_id"/>
                            <field name="pet_id" domain="[('owner_id', '=', owner_id)]"/>
                            <field name="service_id"/>
                            <field name="doctor_id"/>
                        </group>
                        <group>
                            <field name="date"/>
                            <field name="room_id"/>
                            <field name="location_id"/>
                        </group>
                    </group>
                </sheet>
                <chatter/>
            </form>
        </field>
    </record>

    <!-- Appointment Calendar View -->
    <record id="view_pet_clinic_appointment_calendar" model="ir.ui.view">
        <field name="name">pet_clinic.appointment.calendar</field>
        <field name="model">pet_clinic.appointment</field>
        <field name="arch" type="xml">
            <calendar string="Appointments"
                      date_start="date"
                      date_stop="date_stop"
                      color="doctor_id"
                      mode="month"
                      quick_create="0"
                      event_open_popup="1">
                <field name="name"/>
                <field name="pet_id"/>
                <field name="doctor_id"/>
                <field name="owner_id"/>
            </calendar>
        </field>
    </record>

    <!-- Appointment Kanban View -->
    <record id="view_pet_clinic_appointment_kanban" model="ir.ui.view">
        <field name="name">pet_clinic.appointment.kanban</field>
        <field name="model">pet_clinic.appointment</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state" class="o_kanban_small_column">
                <field name="name"/>
                <field name="owner_id"/>
                <field name="pet_id"/>
                <field name="doctor_id"/>
                <field name="date"/>
                <field name="state"/>
                <field name="color"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_content">
                            <strong>
                                <field name="name"/>
                            </strong>
                            <div>
                                <i class="fa fa-user me-1"/> <field name="owner_id"/>
                            </div>
                            <div>
                                <i class="fa fa-paw me-1"/> <field name="pet_id"/>
                            </div>
                            <div>
                                <i class="fa fa-user-md me-1"/> <field name="doctor_id"/>
                            </div>
                            <div>
                                <i class="fa fa-clock-o me-1"/> <field name="date"/>
                            </div>
                            <div>
                                <field name="state" widget="label_selection" options="{'classes': {'draft': 'info', 'confirmed': 'warning', 'done': 'success', 'cancel': 'danger'}}"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- Appointment Search View -->
    <record id="view_pet_clinic_appointment_search" model="ir.ui.view">
        <field name="name">pet_clinic.appointment.search</field>
        <field name="model">pet_clinic.appointment</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="owner_id"/>
                <field name="pet_id"/>
                <field name="doctor_id"/>
                <filter name="draft" string="Draft" domain="[('state','=','draft')]"/>
                <filter name="confirmed" string="Confirmed" domain="[('state','=','confirmed')]"/>
                <filter name="done" string="Done" domain="[('state','=','done')]"/>
                <filter name="today" string="Today" domain="[('date','&gt;=', (context_today()).strftime('%Y-%m-%d')),('date','&lt;',(context_today()+datetime.timedelta(days=1)).strftime('%Y-%m-%d'))]"/>
                <group expand="0" string="Group By">
                    <filter name="group_state" string="Status" context="{'group_by':'state'}"/>
                    <filter name="group_doctor" string="Doctor" context="{'group_by':'doctor_id'}"/>
                    <filter name="group_location" string="Location" context="{'group_by':'location_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Appointment Action -->
    <record id="action_pet_clinic_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">pet_clinic.appointment</field>
        <field name="view_mode">calendar,list,kanban,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Schedule your first appointment!
            </p>
        </field>
    </record>

</odoo>
